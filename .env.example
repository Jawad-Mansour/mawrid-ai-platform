# =============================================================================
# Mawrid AI Platform — Environment Variables Reference
# Feature: All features (cross-cutting configuration)
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://mawrid:password@localhost:5432/mawrid
DATABASE_URL_SYNC=postgresql://mawrid:password@localhost:5432/mawrid  # alembic only

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (RS256 — generate with: openssl genrsa -out private.pem 2048) ---
JWT_PRIVATE_KEY_PATH=./backend/certs/private.pem
JWT_PUBLIC_KEY_PATH=./backend/certs/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15   # memory-only, never persisted
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7      # httpOnly cookie

# --- Widget JWT (storefront embed — separate key pair) ---
WIDGET_JWT_PRIVATE_KEY_PATH=./backend/certs/widget_private.pem
WIDGET_JWT_ALGORITHM=RS256
WIDGET_JWT_EXPIRE_MINUTES=15

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL_ENRICHMENT=gpt-4o
OPENAI_MODEL_RAG=gpt-4o
OPENAI_MODEL_INTENT_TIER3=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# --- Payments ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # HMAC-SHA256 verified
OMT_API_KEY=...
OMT_WEBHOOK_SECRET=...                 # HMAC-SHA256 verified
WHISH_API_KEY=...
WHISH_WEBHOOK_SECRET=...              # HMAC-SHA256 verified

# --- n8n ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=...
N8N_WEBHOOK_SECRET=...                # HMAC-SHA256 verified

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- LangSmith (observability) ---
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=mawrid-ai-platform

# --- Vault (secrets management — production) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root  # dev mode only

# --- Application ---
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_STANDARD=100   # req/min
RATE_LIMIT_PREMIUM=500    # req/min

# --- Enrichment Pipeline ---
ENRICHMENT_PARENT_CHUNK_TOKENS=1024
ENRICHMENT_CHILD_CHUNK_TOKENS=256
ENRICHMENT_MAX_RETRIES=3
ENRICHMENT_DLQ_THRESHOLD=3

# --- Supplier Scorer ---
SUPPLIER_SCORE_MATCH_THRESHOLD_AUTO=0.9    # ≥ this → auto-match
SUPPLIER_SCORE_MATCH_THRESHOLD_HITL=0.3   # 0.3–0.9 → HITL; < 0.3 → HITL "create?"

# --- Customer Matcher ---
CUSTOMER_MATCH_THRESHOLD_AUTO=0.85         # ≥ this → auto-match
CUSTOMER_MATCH_THRESHOLD_HITL=0.3          # 0.3–0.85 → HITL; < 0.3 → auto-create

# --- Email (SendGrid) ---
# Used for: dunning messages, PO sends, fulfillment notifications
SENDGRID_API_KEY=SG....
EMAIL_FROM_ADDRESS=no-reply@mawrid.app
EMAIL_FROM_NAME=Mawrid Platform

# --- SMS (Twilio) — B2C capstone Track 4 (WhatsApp deferred to Wave 1) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
