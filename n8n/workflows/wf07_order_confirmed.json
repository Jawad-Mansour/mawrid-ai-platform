              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"personalizations\": [{ \"to\": [{ \"email\": \"{{ $('Webhook').item.json.body.customer_email }}\" }] }], \"from\": { \"email\": \"no-reply@mawrid.ai\", \"name\": \"Mawrid\" }, \"subject\": \"Your Order {{ $('Webhook').item.json.body.order_id }} — Invoice\", \"content\": [{ \"type\": \"text/html\", \"value\": \"<p>Dear customer,</p><p>Thank you for your order. You can download your invoice here: <a href='{{ $json.pdf_url }}'>Download Invoice</a></p><p>Order ID: {{ $('Webhook').item.json.body.order_id }}</p>\" }] }",
        "options": {
          "timeout": 30000
        }
      },
      "id": "b0007-0006-4000-8000-000000000006",
      "name": "Email Invoice to Consumer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1120, 220]
    },
    {
